{
  "name": "senior-capstone-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev . --compatibility-date=2026-05-18",
    "build:public-site": "powershell -NoProfile -NonInteractive -ExecutionPolicy Bypass -File scripts/run-npm-script.ps1 build:public-site",
    "dev:public-site": "npm run build:public-site && wrangler pages dev public-companion --compatibility-date=2026-05-18 --port 8789",
    "dev:alpha": "wrangler pages dev . --compatibility-date=2026-05-18 --port 8788",
    "deploy": "wrangler pages deploy . --project-name=senior-capstone-app",
    "deploy:public-site": "npm run build:public-site && wrangler pages deploy public-companion --project-name=senior-capstone-public",
    "deploy:preview": "wrangler pages deploy . --project-name=senior-capstone-app --branch alpha",
    "db:migrate:local": "wrangler d1 migrations apply senior-capstone-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply senior-capstone-db --remote",
    "check": "powershell -NoProfile -NonInteractive -ExecutionPolicy Bypass -File scripts/run-npm-script.ps1 check",
    "check:alpha": "powershell -NoProfile -NonInteractive -ExecutionPolicy Bypass -File scripts/run-npm-script.ps1 check:alpha",
    "check:alpha-contract": "powershell -NoProfile -NonInteractive -ExecutionPolicy Bypass -File scripts/run-npm-script.ps1 check:alpha-contract",
    "check:automation": "powershell -NoProfile -NonInteractive -ExecutionPolicy Bypass -File scripts/run-npm-script.ps1 check:automation",
    "check:predeploy-gate": "powershell -NoProfile -NonInteractive -ExecutionPolicy Bypass -File scripts/run-npm-script.ps1 check:predeploy-gate",
    "check:production-surfaces": "powershell -NoProfile -NonInteractive -ExecutionPolicy Bypass -File scripts/run-npm-script.ps1 check:production-surfaces",
